# ==========================================
# E-COMMERCE ADMIN CMS - FRONTEND
# Environment Configuration Template
# ==========================================

# ==========================================
# API CONFIGURATION
# ==========================================
# Backend API URL (without trailing slash)
VITE_API_URL=http://localhost:5000/api/v1

# Alternative for production:
# VITE_API_URL=https://api.yourcompany.com/api/v1

# ==========================================
# APPLICATION SETTINGS
# ==========================================
# App name displayed in browser
VITE_APP_NAME=CSM Admin

# App version
VITE_APP_VERSION=1.0.0

# Environment
VITE_ENV=development

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable/disable features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=false

# ==========================================
# THIRD-PARTY SERVICES (Optional)
# ==========================================
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry for error tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==========================================
# STORAGE & CACHE SETTINGS
# ==========================================
# LocalStorage key prefix
VITE_STORAGE_PREFIX=csm_

# Session timeout (milliseconds)
VITE_SESSION_TIMEOUT=3600000

# ==========================================
# UI SETTINGS
# ==========================================
# Items per page in tables
VITE_DEFAULT_PAGE_SIZE=20

# Max file upload size in MB
VITE_MAX_FILE_SIZE=5

# ==========================================
# WEBSOCKET (Optional)
# ==========================================
# For real-time features
# VITE_WS_URL=ws://localhost:5000

# ==========================================
# PRODUCTION NOTES
# ==========================================
# 1. Update VITE_API_URL to production URL
# 2. Set VITE_ENV=production
# 3. Configure analytics tracking IDs
# 4. Enable error monitoring (Sentry)
# 5. Verify CORS settings on backend
# 6. Use HTTPS URLs in production
# ==========================================
